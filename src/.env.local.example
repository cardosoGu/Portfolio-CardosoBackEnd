# Configuração de email — coloque no .env.local (nunca commitar no git!)
# 
# SMTP_USER  → seu Gmail (ex: seunome@gmail.com)
# SMTP_PASS  → Senha de App do Google (não é sua senha normal!)
#              Gere em: myaccount.google.com → Segurança → Senhas de app
# CONTACT_EMAIL → email que vai RECEBER as mensagens (pode ser o mesmo)

SMTP_USER=seugmail@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx
CONTACT_EMAIL=cardosogustavo667@yahoo.com
